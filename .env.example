# Copy to `.env` and fill in.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=wagent
POSTGRES_PASSWORD=wagent
POSTGRES_DB=wagent_farm
DATABASE_URL=postgres://wagent:wagent@localhost:5432/wagent_farm

# Provider account keys; per-tenant model stays config-driven, never hardcoded.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
