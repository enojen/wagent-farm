# Copy to `.env` and fill in. `.env*` is git-ignored except this example.

# Postgres (matches docker-compose.yml defaults for local dev)
POSTGRES_USER=wagent
POSTGRES_PASSWORD=wagent
POSTGRES_DB=wagent_farm
DATABASE_URL=postgres://wagent:wagent@localhost:5432/wagent_farm

# LLM provider keys. Per-tenant *model* is config-driven (never hardcoded);
# these are the account credentials the model router uses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
