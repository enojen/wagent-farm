{
  "name": "@wagent/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root ../.. packages/db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsc -b && node --env-file-if-exists=../../.env dist/seed/run.js"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "@types/pg": "catalog:",
    "@electric-sql/pglite": "catalog:",
    "vitest": "catalog:"
  }
}
