{
  "name": "wagent-farm",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "format": "prettier --write .",
    "db:ping": "docker compose exec -T db pg_isready -U wagent -d wagent_farm",
    "db:generate": "pnpm --filter @wagent/db db:generate",
    "db:migrate": "pnpm --filter @wagent/db db:migrate",
    "db:seed": "pnpm --filter @wagent/db db:seed"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
